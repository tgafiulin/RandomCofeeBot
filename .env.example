BOT_TOKEN=

# SQLite: path относительно каталога prisma/ (где schema.prisma)
DATABASE_URL="file:./dev.db"

# Optional. Comma-separated group/supergroup IDs (negative numbers, e.g. -1001234567890).
# If unset, the bot accepts any group (fine for local dev; set in production).
# If set but empty, no group is allowed (only private chats).
ALLOWED_GROUP_IDS=

# --- Cron (optional)
# Нужен непустой ALLOWED_GROUP_IDS. Время опроса и матчинга — в личке: /settings → группа, затем /schedule, /cron, /crontz.
# Пояс по умолчанию для cron (если у группы нет /crontz) — константа DEFAULT_CRON_TIMEZONE в src/cronConstants.ts.
# /scheduleoff и /scheduleon — выключить или включить авто-опрос и авто-пары для выбранной группы.
